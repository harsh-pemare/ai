% Male members
male(john).
male(mike).
male(tom).
male(alex).

% Female members
female(mary).
female(susan).
female(lucy).
female(anna).

% Parent relationships
parent(john, mike).
parent(john, lucy).

parent(mary, mike).
parent(mary, lucy).

parent(mike, tom).
parent(mike, anna).

parent(susan, tom).
parent(susan, anna).

parent(lucy, alex).


% Father rule
father(Father, Child) :-
    male(Father),
    parent(Father, Child).

% Mother rule
mother(Mother, Child) :-
    female(Mother),
    parent(Mother, Child).

% Sibling rule
sibling(Sibling1, Sibling2) :-
    parent(Parent, Sibling1),
    parent(Parent, Sibling2),
    Sibling1 \= Sibling2.

% Ancestor rule (direct parent)
ancestor(Ancestor, Descendant) :-
    parent(Ancestor, Descendant).

% Ancestor rule (recursive)
ancestor(Ancestor, Descendant) :-
    parent(Parent, Descendant),
    ancestor(Ancestor, Parent).


:- initialization(main).

main :-
    (
        father(mary, susan) ->
        write('true'), nl;
        write('false'), nl
    ).
